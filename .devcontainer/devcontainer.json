{
    "name": "rpa-dev",
    "build": { 
        "dockerfile": "Dockerfile" 
    },
    "runArgs": ["--name", "devcontainer-${localWorkspaceFolderBasename}"],  // containerName is not supported without docker compose
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    // "features": { set in dockerfile
        // "ghcr.io/devcontainers/features/git:1": {},
        // "ghcr.io/devcontainers/features/azure-cli:1": {},
        // "ghcr.io/devcontainers-extra/features/uv:1": {}
    // },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
                "python.terminal.activateEnvironment": true,
                "python.testing.pytestEnabled": true,
                "[python]": {
                    "editor.formatOnSave": true,
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit",
                        "source.fixAll.ruff": "explicit"
                    }
                },
                "ruff.format.preview": true,
                "[markdown]": {
                    "editor.formatOnSave": true,
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "html.format.enable": true,
                "files.associations": {
                    "*.html": "jinja-html"
                },
                "cSpell.userWords": [
                    "htmx",
                    "pytest",
                    "uvicorn",
                    "fastapi",
                    "pydantic",
                    "ruff",
                    "tailwindcss"
                ],
                "cSpell.enabledFileTypes": {
                    "jinja-html": true,
                    "python": true,
                    "markdown": true
                },
                "cSpell.diagnosticLevel": "Hint" // Warning, Information
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "samuelcolvin.jinjahtml",
                "dzhavat.css-initial-value",
                "streetsidesoftware.code-spell-checker"
            ]
        }
    },
    "remoteUser": "vscode",
    "updateRemoteUserUID": true, // match the vscode user in container with the host user to avoid permission issues on mounted volumes
    "mounts": [
        // local named volumes
        "source=venv-${localWorkspaceFolderBasename},target=/workspace/.venv,type=volume",
        "source=sisyphus-${localWorkspaceFolderBasename},target=/workspace/.sisyphus,type=volume",
        // shared configs: windows user: change ${localEnv:HOME} to %USERPROFILE% if troubles
        "source=${localEnv:HOME}/.local/share/opencode/auth.json,target=/home/vscode/.local/share/opencode/auth.json,type=bind",
        "source=${localEnv:HOME}/.config/opencode,target=/home/vscode/.config/opencode,type=bind",
        // global cache
        "source=uv-shared-cache-py314,target=/home/vscode/.cache/uv,type=volume",
        "source=opencode-global-cache,target=/home/vscode/.cache/opencode,type=volume"
    ],
    "containerEnv": {
        "UV_LINK_MODE": "copy",
        "OMO_AUTO_RECOVERY": "true",
        "OLLAMA_HOST": "http://host.orb.internal:11434"
    },
    "forwardPorts": [],
    "postCreateCommand": "sudo chown -R vscode:vscode /workspace/.venv /home/vscode/.local /home/vscode && uv sync --all-packages --all-extras"
}
